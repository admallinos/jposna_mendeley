<?xml version="1.0" encoding="utf-8"?>
<style xmlns="http://purl.org/net/xbiblio/csl" page-range-format="minimal" class="in-text" version="1.0" demote-non-dropping-particle="sort-only" default-locale="en-US">
  <info>
    <title>Journal of the Pediatric Orthopaedic Society of North America</title>
    <title-short>JPOSNA</title-short>
    <id>http://www.zotero.org/styles/journal-of-the-pediatric-orthopaedic-society-of-north-america</id>
    <link href="http://www.zotero.org/styles/journal-of-the-pediatric-orthopaedic-society-of-north-america" rel="self"/>
    <link href="http://www.zotero.org/styles/elsevier-vancouver" rel="template"/>
    <link href="https://www.sciencedirect.com/journal/journal-of-the-pediatric-orthopaedic-society-of-north-america/publish/guide-for-authors" rel="documentation"/>
    <author>
      <name>OpenAI</name>
    </author>
    <category citation-format="numeric"/>
    <category field="medicine"/>
    <issn>2768-2765</issn>
    <summary>Numeric JPOSNA style with square-bracket citations, citation-order bibliography, minimal page ranges, and first-six-authors-plus-et-al handling.</summary>
    <updated>2026-03-16T00:00:00+00:00</updated>
    <rights license="http://creativecommons.org/licenses/by-sa/3.0/">This work is licensed under a Creative Commons Attribution-ShareAlike 3.0 License</rights>
  </info>

  <macro name="author">
    <names variable="author">
      <name initialize-with="" delimiter=", " delimiter-precedes-last="always" name-as-sort-order="all" sort-separator=" "/>
      <label form="long" prefix=", "/>
      <substitute>
        <names variable="editor"/>
        <names variable="translator"/>
      </substitute>
    </names>
  </macro>

  <macro name="editor">
    <names variable="editor">
      <name initialize-with="" delimiter=", " delimiter-precedes-last="always" name-as-sort-order="all" sort-separator=" "/>
      <label form="long" prefix=", "/>
    </names>
  </macro>

  <macro name="year-date">
    <choose>
      <if variable="issued">
        <date variable="issued">
          <date-part name="year"/>
        </date>
      </if>
      <else>
        <text term="no date" form="short"/>
      </else>
    </choose>
  </macro>

  <macro name="edition">
    <choose>
      <if is-numeric="edition">
        <group delimiter=" ">
          <number variable="edition" form="ordinal"/>
          <text term="edition" form="short"/>
        </group>
      </if>
      <else-if variable="edition">
        <text variable="edition"/>
      </else-if>
    </choose>
  </macro>

  <macro name="publisher">
    <group delimiter=": ">
      <text variable="publisher-place" text-case="title"/>
      <text variable="publisher"/>
    </group>
    <text macro="year-date" prefix="; "/>
  </macro>

  <macro name="repository">
    <choose>
      <if variable="publisher">
        <text variable="publisher"/>
      </if>
      <else-if variable="archive">
        <text variable="archive"/>
      </else-if>
      <else-if variable="container-title">
        <text variable="container-title"/>
      </else-if>
    </choose>
  </macro>

  <macro name="accessed">
    <choose>
      <if variable="accessed">
        <group prefix="[" suffix="]" delimiter=" ">
          <text term="accessed"/>
          <date variable="accessed">
            <date-part name="day"/>
            <date-part name="month" form="long" prefix=" "/>
            <date-part name="year" prefix=" "/>
          </date>
        </group>
      </if>
    </choose>
  </macro>

  <macro name="doi">
    <text variable="DOI" prefix="https://doi.org/"/>
  </macro>

  <macro name="url-with-accessed">
    <choose>
      <if variable="URL">
        <group delimiter=" ">
          <text variable="URL"/>
          <text macro="accessed"/>
        </group>
      </if>
    </choose>
  </macro>

  <macro name="access">
    <choose>
      <if variable="DOI">
        <text macro="doi"/>
      </if>
      <else-if variable="URL">
        <text macro="url-with-accessed"/>
      </else-if>
    </choose>
  </macro>

  <citation collapse="citation-number">
    <sort>
      <key variable="citation-number"/>
    </sort>
    <layout prefix="[" suffix="]" delimiter=",">
      <text variable="citation-number"/>
    </layout>
  </citation>

  <bibliography entry-spacing="0" second-field-align="flush" et-al-min="7" et-al-use-first="6">
    <layout suffix=".">
      <text variable="citation-number" prefix="[" suffix="]"/>
      <text macro="author" suffix=". "/>
      <choose>
        <if type="webpage post-weblog" match="any">
          <group delimiter=", ">
            <text variable="title"/>
            <group delimiter="; ">
              <text variable="URL"/>
              <group delimiter=" ">
                <text macro="year-date"/>
                <text macro="accessed"/>
              </group>
            </group>
          </group>
        </if>

        <else-if type="article-journal article-magazine article-newspaper" match="any">
          <group delimiter=". ">
            <text variable="title"/>
            <group delimiter="">
              <text variable="container-title" form="short" strip-periods="true" suffix=" "/>
              <group delimiter=";">
                <text macro="year-date"/>
                <group>
                  <text variable="volume"/>
                  <text variable="issue" prefix="(" suffix=")"/>
                </group>
              </group>
              <text variable="page" prefix=":"/>
            </group>
          </group>
          <text macro="access" prefix=". "/>
        </else-if>

        <else-if type="book graphic legal_case legislation motion_picture song" match="any">
          <group delimiter=". ">
            <text variable="title"/>
            <text variable="volume" prefix="vol. "/>
            <text macro="edition"/>
            <text macro="publisher"/>
          </group>
          <text macro="access" prefix=". "/>
        </else-if>

        <else-if type="chapter paper-conference" match="any">
          <group delimiter=". ">
            <text variable="title"/>
            <group delimiter=". ">
              <group delimiter="">
                <text term="in" text-case="sentence" suffix=": "/>
                <text macro="editor"/>
              </group>
              <group delimiter=", ">
                <text variable="container-title"/>
                <text variable="volume" prefix="vol. "/>
                <text macro="edition"/>
                <text macro="publisher"/>
                <group delimiter=" ">
                  <label variable="page" form="short" plural="never"/>
                  <text variable="page"/>
                </group>
              </group>
            </group>
          </group>
          <text macro="access" prefix=". "/>
        </else-if>

        <else-if type="dataset" match="any">
          <group delimiter=", ">
            <text variable="title" suffix=" [dataset]"/>
            <text macro="repository"/>
            <text variable="version"/>
          </group>
          <text macro="year-date" prefix="; "/>
          <text macro="access" prefix=". "/>
        </else-if>

        <else-if type="software" match="any">
          <group delimiter=", ">
            <group delimiter=" ">
              <text variable="title"/>
              <text variable="version" prefix="(Version " suffix=")"/>
              <text value="[software]"/>
            </group>
            <text macro="repository"/>
            <text macro="year-date"/>
          </group>
          <text macro="access" prefix=". "/>
        </else-if>

        <else-if type="patent" match="any">
          <group delimiter=", ">
            <group delimiter=". ">
              <text variable="title"/>
              <text variable="number"/>
            </group>
            <text macro="year-date"/>
          </group>
          <text macro="access" prefix=". "/>
        </else-if>

        <else-if type="thesis" match="any">
          <group delimiter=". ">
            <text variable="title"/>
            <text variable="genre"/>
            <group delimiter=", ">
              <text variable="publisher"/>
              <text macro="year-date"/>
            </group>
          </group>
          <text macro="access" prefix=". "/>
        </else-if>

        <else-if type="report" match="any">
          <group delimiter=". ">
            <text variable="title"/>
            <text variable="genre"/>
            <text variable="number"/>
            <text macro="publisher"/>
          </group>
          <text macro="access" prefix=". "/>
        </else-if>

        <else>
          <group delimiter=". ">
            <text variable="title"/>
            <text variable="container-title"/>
            <text macro="publisher"/>
          </group>
          <text macro="access" prefix=". "/>
        </else>
      </choose>
    </layout>
  </bibliography>
</style>
