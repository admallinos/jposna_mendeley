<?xml version="1.0" encoding="utf-8"?>
<style xmlns="http://purl.org/net/xbiblio/csl" page-range-format="minimal" class="in-text" version="1.0" demote-non-dropping-particle="sort-only" default-locale="en-US">
  <info>
    <title>Journal of the Pediatric Orthopaedic Society of North America</title>
    <title-short>JPOSNA</title-short>
    <id>http://www.zotero.org/styles/journal-of-the-pediatric-orthopaedic-society-of-north-america</id>
    <link href="http://www.zotero.org/styles/journal-of-the-pediatric-orthopaedic-society-of-north-america" rel="self"/>
    <link href="http://www.zotero.org/styles/elsevier-vancouver" rel="template"/>
    <link href="https://www.sciencedirect.com/journal/journal-of-the-pediatric-orthopaedic-society-of-north-america/publish/guide-for-authors" rel="documentation"/>
    <author>
      <name>Richard Karnesky</name>
      <email>karnesky+zotero@gmail.com</email>
      <uri>http://arc.nucapt.northwestern.edu/Richard_Karnesky</uri>
    </author>
    <contributor>
      <name>OpenAI</name>
    </contributor>
    <category citation-format="numeric"/>
    <category field="medicine"/>
    <issn>2768-2765</issn>
    <summary>Custom JPOSNA style based on Elsevier Vancouver/NLM guidance: numeric citations in square brackets, citation sequence bibliography, minimal page ranges, first 6 authors followed by et al., and abbreviated journal titles.</summary>
    <updated>2026-03-16T00:30:00+00:00</updated>
    <rights license="http://creativecommons.org/licenses/by-sa/3.0/">This work is licensed under a Creative Commons Attribution-ShareAlike 3.0 License.</rights>
  </info>
  <macro name="author">
    <names variable="author">
      <name initialize-with="" delimiter=", " delimiter-precedes-last="always" name-as-sort-order="all" sort-separator=" "/>
      <label form="long" prefix=", "/>
      <substitute>
        <names variable="editor"/>
        <names variable="translator"/>
      </substitute>
    </names>
  </macro>
  <macro name="editor">
    <names variable="editor">
      <name initialize-with="" delimiter=", " delimiter-precedes-last="always" name-as-sort-order="all" sort-separator=" "/>
      <label form="long" prefix=", " suffix="."/>
    </names>
  </macro>
  <macro name="year-date">
    <choose>
      <if variable="issued">
        <date variable="issued">
          <date-part name="year"/>
        </date>
      </if>
      <else>
        <text term="no date" form="short"/>
      </else>
    </choose>
  </macro>
  <macro name="publisher">
    <text variable="publisher-place" suffix=": " text-case="title"/>
    <text variable="publisher" suffix="; "/>
    <text macro="year-date"/>
  </macro>
  <macro name="edition">
    <choose>
      <if is-numeric="edition">
        <group delimiter=" ">
          <number variable="edition" form="ordinal"/>
          <text term="edition" form="short"/>
        </group>
      </if>
      <else>
        <text variable="edition"/>
      </else>
    </choose>
  </macro>
  <macro name="accessed-date">
    <choose>
      <if variable="accessed">
        <group prefix="[" suffix="]" delimiter=" ">
          <text term="accessed"/>
          <date variable="accessed" delimiter=" ">
            <date-part name="day"/>
            <date-part name="month" form="long"/>
            <date-part name="year"/>
          </date>
        </group>
      </if>
    </choose>
  </macro>
  <macro name="access-doi-or-url">
    <choose>
      <if variable="DOI">
        <text variable="DOI" prefix="https://doi.org/"/>
      </if>
      <else-if variable="URL">
        <text variable="URL"/>
      </else-if>
    </choose>
  </macro>
  <macro name="web-reference-access">
    <group delimiter=" ">
      <group delimiter="; ">
        <text variable="URL"/>
        <text macro="year-date"/>
      </group>
      <text macro="accessed-date"/>
    </group>
  </macro>
  <macro name="repository">
    <choose>
      <if variable="publisher">
        <text variable="publisher"/>
      </if>
      <else-if variable="container-title">
        <text variable="container-title"/>
      </else-if>
    </choose>
  </macro>
  <macro name="periodical-title">
    <choose>
      <if type="article-journal">
        <choose>
          <if variable="container-title-short">
            <text variable="container-title-short" strip-periods="true"/>
          </if>
          <else>
            <text variable="container-title" form="short" strip-periods="true"/>
          </else>
        </choose>
      </if>
      <else>
        <text variable="container-title"/>
      </else>
    </choose>
  </macro>
  <citation collapse="citation-number">
    <sort>
      <key variable="citation-number"/>
    </sort>
    <layout prefix="[" suffix="]" delimiter=",">
      <text variable="citation-number"/>
    </layout>
  </citation>
  <bibliography entry-spacing="0" second-field-align="flush" et-al-min="7" et-al-use-first="6">
    <layout suffix=".">
      <text variable="citation-number" prefix="[" suffix="]"/>
      <text macro="author" suffix=". "/>
      <choose>
        <if type="bill book graphic legal_case legislation motion_picture report song" match="any">
          <group delimiter=". ">
            <text variable="title"/>
            <text variable="volume" prefix="vol. "/>
            <text macro="edition"/>
            <text macro="publisher"/>
          </group>
        </if>
        <else-if type="chapter paper-conference" match="any">
          <group delimiter=", ">
            <group delimiter=". ">
              <text variable="title"/>
              <group>
                <text term="in" text-case="sentence" suffix=": "/>
                <text macro="editor"/>
              </group>
              <group delimiter=", ">
                <text variable="container-title"/>
                <text variable="volume" prefix="vol. "/>
              </group>
              <text macro="edition"/>
            </group>
            <text macro="publisher"/>
            <group delimiter=" ">
              <label variable="page" form="short" plural="never"/>
              <text variable="page"/>
            </group>
          </group>
        </else-if>
        <else-if type="patent">
          <group delimiter=", ">
            <group delimiter=". ">
              <text variable="title"/>
              <text variable="number"/>
            </group>
            <text macro="year-date"/>
          </group>
        </else-if>
        <else-if type="thesis">
          <group delimiter=". ">
            <text variable="title"/>
            <text variable="genre"/>
            <group delimiter=", ">
              <text variable="publisher"/>
              <text macro="year-date"/>
            </group>
          </group>
        </else-if>
        <else-if type="webpage post-weblog post" match="any">
          <group delimiter=", ">
            <text variable="title"/>
            <text macro="web-reference-access"/>
          </group>
        </else-if>
        <else-if type="dataset">
          <group delimiter=", ">
            <text variable="title" suffix=" [dataset]"/>
            <text macro="repository"/>
            <text variable="version" prefix="v"/>
          </group>
          <text macro="year-date" prefix="; "/>
          <text macro="access-doi-or-url" prefix=". "/>
        </else-if>
        <else-if type="software">
          <group delimiter=", ">
            <group delimiter=" ">
              <text variable="title"/>
              <choose>
                <if variable="version">
                  <group prefix="(" suffix=")">
                    <text value="Version "/>
                    <text variable="version"/>
                  </group>
                </if>
              </choose>
              <text value="[software]"/>
            </group>
            <text macro="repository"/>
            <text macro="year-date"/>
          </group>
          <text macro="access-doi-or-url" prefix=". "/>
        </else-if>
        <else>
          <group delimiter=":">
            <group delimiter=" ">
              <group delimiter=". ">
                <text variable="title"/>
                <text macro="periodical-title"/>
              </group>
              <group delimiter=";">
                <text macro="year-date"/>
                <text variable="volume"/>
              </group>
            </group>
            <text variable="page" form="short"/>
          </group>
        </else>
      </choose>
      <choose>
        <if type="bill book graphic legal_case legislation motion_picture report song thesis patent chapter paper-conference webpage post-weblog post dataset software" match="none">
          <text macro="access-doi-or-url" prefix=". "/>
        </if>
      </choose>
    </layout>
  </bibliography>
</style>
